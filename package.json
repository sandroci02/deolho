{
  "name": "deolho",
  "version": "1.0.0",
  "description": "deOlho - Monitor de Câmeras RTSP",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "dev": "node --watch server.js",
    "app": "electron .",
    "fix:dev": "npm rebuild better-sqlite3",
    "fix:app": "electron-rebuild -f -w better-sqlite3",
    "dev:fixed": "npm run fix:dev && npm run dev",
    "app:fixed": "npm run fix:app && npm run app",
    "dist": "electron-builder",
    "postinstall": "electron-rebuild"
  },
  "build": {
    "appId": "com.deolho.monitor",
    "productName": "deOlho",
    "icon": "icone.png",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "files": [
      "**/*",
      "!dist/*",
      "!.git/*"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "ini": "^5.0.0",
    "onvif": "^0.8.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}
